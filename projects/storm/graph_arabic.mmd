  GEN_QUERIES --> SEARCH_SIFT[search_and_sift استعلامات عبر YouRM You.com API أعلى k 10 مقال ويكيبيديا الحقيقي مستبعد مصادر موثوقة BingSearch VectorRM إلخ]

  SEARCH_SIFT --> GEN_ANS[موجه GenAnswer
أنت خبير يمكنه استخدام معلومات بفعالية تتحدث مع كاتب ويكيبيديا يريد كتابة صفحة حول موضوع تعرفه جمعت معلومات ذات صلة وستستخدم الآن معلومات لتشكيل رد اجعل ردك غني بالمعلومات قدر الإمكان وتأكد دعم كل جملة بالمعلومات المجمعة إدخال موضوع سؤال معلومات مجمعة إخراج إجابة a غنية كل جملة مدعومة خبير مؤسس مصادر إنترنت موثوقة]

  GEN_ANS --> HIST_A[تاريخ يضم إجابة]

  HIST_A --> R_APPEND[مراجع تضم مصادر جمع مراجع]

  R_APPEND --> MORE_ROUNDS{هل بقي جولات؟}
  MORE_ROUNDS -->|نعم| ROUND_LOOP
  MORE_ROUNDS -->|لا| CONVO_APPEND[محادثات تضم تاريخ محادثة جمع محادثات {C0..CN} كل M أزواج سؤال/جواب إجمالي ~30 محادثة متابعة متعمقة ترتيب نقل ميزانية بحث تكراري مؤسس إنترنت]

  CONVO_APPEND --> MORE_PERSP{هل بقي وجهات؟}
  MORE_PERSP -->|نعم| PERS_LOOP
  MORE_PERSP -->|لا| DIRECT_OUTLINE[موجه DirectGenOutline اكتب مخططًا لصفحة ويكيبيديا صيغة استخدم # عنوان ## عنوان فرعي ### فرعي فرعي إلخ لا تضمن معلومات أخرى إدخال موضوع إخراج مسودة مخطط OD عام لكن منظم إطار مرتكز معرفة جوهرية]

  DIRECT_OUTLINE --> REFINE_OUTLINE[موجه RefineOutline حسن مخططًا لصفحة ويكيبيديا لديك بالفعل مسودة تغطي معلومات عامة الآن تريد تحسينه بناء على معلومات تعلمتها من محادثة بحث معلومات لجعله أكثر شمولًا صيغة نفس # ## ### إدخال موضوع تاريخ محادثة مخطط حالي إخراج مخطط محسن O شامل مستخدم لإنتاج مقال كامل]

  REFINE_OUTLINE --> WRITING_STAGE[مرحلة كتابة بناء على مراجع R مجمعة مخطط O مطور خلال ما قبل كتابة مقال كامل مؤلف قسمًا بقسم]

  WRITING_STAGE --> SEC_LOOP{لكل عنوان قسم + فرعي في O}

  SEC_LOOP --> RETRIEVE_SEC[استرجاع مستندات ذات صلة من R بناء على تشابه دلالي Sentence-BERT باستخدام عنوان قسم + فرعي كاستعلام]

  RETRIEVE_SEC --> GEN_SECTION[توليد قسم مع استشهادات LLM موجه نص قسم مع استشهادات كل ادعاء مدعوم مراجع صيغة [1][2]]

  GEN_SECTION --> MORE_SEC{هل بقي أقسام؟}
  MORE_SEC -->|نعم| SEC_LOOP
  MORE_SEC -->|لا| CONCAT[ربط كل الأقسام تشكل مسودة مقال كامل]

  CONCAT --> POLISH[تلميع حذف معلومات مكررة تحسين تماسك موجه LLM حذف معلومات مكررة عبر أقسام محافظة تغطية استشهادات إرجاع مقال مصقول]

  POLISH --> LEAD[ملخص مقدمة توليف معايير أسلوب ويكيبيديا LLM مستخدم لتوليف ملخص مقال كامل يشكل قسم مقدمة في البداية مقدمة 2-3 فقرات نظرة عامة موجزة نقاط رئيسية إرجاع مقدمة + مقال مصقول نهائي S = s1 s2 ... sn كل si يستشهد قائمة مستندات في R plus عناصر تنظيمية عناوين لا استشهادات]

  LEAD --> EVAL_FRESH[مجموعة FreshWiki إنشاء لتخفيف تسريب بحث عن مقالات حديثة منشأة معدلة بشدة بعد cutoff تدريب LLMs اختبار عملية مكررة تواريخ مستقبلة LLMs جديدة تركيز أفضل 100 صفحة أكثر تحريرًا كل شهر فبراير2022-سبتمبر2023 عبر واجهة ويكي فلترة جودة B-class ORES استبعاد قوائم لا أقسام فرعية نص عادي فقط موارد https://github.com/stanford-oval/storm]

  EVAL_FRESH --> EVAL_OUTLINE[تقييم مخطط استدعاء ناعم عنوان مجموعة A={Ai} عد ناعم عكس مجموع تشابه count(Ai)=1/sum_j Sim(Ai,Aj) Sim=cos تضمين embed(Ai) embed(Aj) تضمين paraphrase-MiniLM-L6-v2 cardinalities card(A)=sum count استدعاء ناعم card(G∩P)/card(G) تقاطع عبر اتحاد card(G∩P)=card(G)+card(P)-card(G∪P) + استدعاء كيان عنوان نسبة كيانات مسماة مغطاة FLAIR NER Akbik 2019]

  EVAL_OUTLINE --> EVAL_ARTICLE[تقييم مقال Prometheus  Kim 2023 13B مقيم مفتوح مصدر يقيّم نص طويل مخصص 1-5 مقياس اهتمام تماسك تنظيم صلة تركيز تغطية جدول8 بدون مرجع مقلص 2000 كلمة إزالة متكررة أقصر قسم + استدعاء دقة استشهاد Gao et al Mistral 7B + خبراء محرري ويكيبيديا منظم +25% مطلق تغطية واسعة +10% مقابل أساس RAG مدفوع مخطط تحديات نقل تحيز مصدر تحيز إنترنت يؤثر مقالات ارتباط مفرط حقائق غير ذات صلة اختلاق روابط آفاق جديدة]

  EVAL_ARTICLE --> COSTORM[امتداد Co-STORM بروتوكول خطاب تعاوني سياسة إدارة أدوار Co-STORM خبراء LLM يولدون إجابات مؤسسة على مصادر معرفة خارجية و/أو يطرحون أسئلة متابعة بناءً على تاريخ خطاب مشرف يولد أسئلة مثيرة للتفكير مستوحاة من معلومات اكتشفها المسترجع لكن لم تستخدم مباشرة أدوار سابقة توليد أسئلة مؤسس! مستخدم بشري مبادرة إما مراقبة خطاب اكتساب فهم أعمق أو مشاركة نشطة محادثة حقن أقوال لتوجيه تركيز نقاش خريطة ذهنية ديناميكية محدثة تنظم معلومات مجمعة هيكل مفاهيمي هرمي تهدف بناء مساحة مفاهيمية مشتركة بين مستخدم بشري والنظام خريطة ذهنية ثبت أنها تساعد تقليل حمل عقلي عندما يصبح الخطاب طويلًا ومتعمقًا معياري للغاية باستخدام dspy litellm تكامل نماذج لغة نماذج تضمين pip install knowledge-storm]

  COSTORM --> END([نهاية STORM مقال كامل مؤسس شبيه ويكيبيديا من الصفر مع استشهادات عرض وعمق مقارن ويكيبيديا عبر أسئلة موجهة منظور محادثات محاكاة تنسيق مخطط توليد قسم بقسم])
