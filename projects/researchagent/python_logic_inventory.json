    {
      "file": "Entity retrieval",
      "equations": {
        "Eq1": "Ret({l0..ln};K)=argmax_{I subset [m]:|I|=k} prod P(ei|E)",
        "Eq2": "argmax prod (prod_{ej in E} P(ej|ei)) * P(ei) where P from normalized K"
      },
      "matrix": "K in R^{m x m} sparse co-occurrence counts + single counts, m unique entities, built from 50,091 papers May-Dec 2023 titles+abstracts via BLINK linker",
      "alternatives": [
        "co-occurrence-based retrieval Eq2",
        "embedding-based retrieval cosine similarity in linker latent space",
        "random entities",
        "w/o entities"
      ]
    },
