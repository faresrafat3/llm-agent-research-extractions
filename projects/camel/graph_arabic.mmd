flowchart TD
  IDEA([فكرة أولية بشرية تطوير روبوت تداول سوق الأسهم]) --> ROLE_ASSIGN[تعيين أدوار مساعد بايثون مبرمج مستخدم متداول أسهم]
  ROLE_ASSIGN --> HUMAN_INPUT[إدخال بشري]
  HUMAN_INPUT --> TASK_SPEC[محدد مهام يجعل المهمة أكثر تحديدًا باستخدام LLM بدلاً من الاعتماد على مدخلات بشرية مهمة محددة تطوير روبوت تداول مع أداة تحليل مشاعر تراقب منصات اجتماعية تعليقات إيجابية سلبية عن سهم معين وتنفيذ تداولات بناءً على نتائج تحليل المشاعر]
  TASK_SPEC --> PA_PU[رسائل نظام PA مساعد و PU مستخدم تمر قبل المحادثات A<-F_PA U<-F_PU F1 F2 نماذج لغة انحدارية واسعة النطاق مستخدم يخدم مخطط مهام تخطيط تفاعلي خطوات ممكنة مساعد ينفذ]
  PA_PU --> MT_INIT[M_t = {(I0,S0)...} فارغ بداية]
  MT_INIT --> INSTR0[تعليمات تثبيت مكتبات بايثون ضرورية لتحليل المشاعر وتداول الأسهم إدخال لا شيء]
  INSTR0 --> SOL0[حل لتثبيت مكتبات ... pip install tweepy textblob yfinance طلب تالي]
  SOL0 --> MT1[M_t = {(I0,S0)}]
  MT1 --> INSTR1[تعليمات استيراد مكتبات ضرورية بايثون]
  INSTR1 --> SOL1[حل كود استيراد tweepy textblob pandas numpy yfinance طلب تالي]
  SOL1 --> LOOP{حلقة المرة القادمة t+1 مستخدم U يأخذ تاريخ M_t يولد I_{t+1} مساعد A يولد S_{t+1} حتى انتهاء}
  LOOP --> TERM_CHECK{انتهاء؟ اكتمال مهمة أو حد أقصى رسائل تكلفة تربيعية مقابل حد رموز مقابل كشف حلقة تحديات قلب أدوار تكرار تعليمات ردود هشة حلقة لا نهائية}
  TERM_CHECK -->|لا| INSTR_NEXT[تعليمات تالية]
  INSTR_NEXT --> SOL_NEXT[حل تالي]
  SOL_NEXT --> LOOP
  TERM_CHECK -->|نعم| DATA_GEN[موجهات توليد بيانات مجتمع ذكاء اصطناعي شكل3 نهج قابل للتوسع معاملات بيانات مولدة باستخدام نموذج LLM تقليل تدخل بشري]
  DATA_GEN --> ROLE_GEN[موجه توليد أدوار مساعد أنت مساعد مفيد يمكنه لعب العديد من الأدوار المختلفة الآن يرجى سرد NUM_ROLES أدوار مختلفة يمكنك لعبها بخبرتك في مجالات متنوعة رتبها ترتيب أبجدي لا شرح مطلوب]
  ROLE_GEN --> USER_ROLE_GEN[موجه توليد أدوار مستخدم يرجى سرد NUM_ROLES أكثر مجموعات شيوعًا وتنوعًا من مستخدمي الإنترنت أو المهن استخدم صيغة مفردة لا شرح رتب أبجدي لا شرح مطلوب]
  USER_ROLE_GEN --> TASK_GEN[موجه توليد مهام سرد NUM_TASKS مهام متنوعة يمكن لـ ASSISTANT_ROLE مساعدة USER_ROLE تعاونيًا لتحقيقها معًا موجز مبدع]
  TASK_GEN --> AI_SOCIETY[مجموعة بيانات مجتمع ذكاء اصطناعي كبيرة محادثة موجهة تعليمات تعاونية لعب أدوار نهج قابل للتوسع سلسلة خطوات أولاً موجه LLM يولد أدوار ممكنة مساعد ومستخدم ثم مجموعة مهام ممكنة يمكن حلها من خلال تعاون بين أدوار مساعد ومستخدم]
  AI_SOCIETY --> CODE_DATASET[مجموعة بيانات كود مهام تعاونية ترميزية قدرات توليد كود HumanEval HumanEval+]
  CODE_DATASET --> MATH_SCI[مجموعات بيانات رياضيات وعلوم لمواضيع مشاكل فرعية مشاكل مولدة تلقائيًا عبر موجه LLMs بدلاً من الاعتماد على مدخلات بشرية سؤال-جواب دورة واحدة]
  MATH_SCI --> MISALIGN[مجموعة بيانات عدم محاذاة محاكاة تطبيقات خبيثة محتملة توضح مخاطر محتملة نظام وكيل مستقل غير محاذى]
  MISALIGN --> EVAL[تقييم وكيل اختيار عشوائي 100 مهمة مجتمع ذكاء اصطناعي تقييم و 100 مهمة كود مجموعة بيانات ثم توظيف نموذج GPT4 تلخيص محتوى حل قائم على محادثة CAMEL يقدم حل نهائي موحد على وجه الخصوص GPT4 يستخدم حيث يمتلك حد رمزي أكبر مناسب للتلخيص التلخيص أيضًا يجعل حل وكلاء CAMEL غير قابل للكشف عبر صيغته مما يسمح بمقارنة أكثر عدلاً لاحقًا حل مقارن مع حل لقطة واحدة مولدة بواسطة gpt-3.5-turbo]
  EVAL --> HUMAN_EVAL[تقييم بشري تقديم كل من حل وكيل CAMEL الملخص وحل لقطة واحدة gpt-3.5-turbo جنبًا إلى جنب لمشاركين بشريين الهوية خلف كل حل غير مكشوفة المشاركون ثم يُطلب منهم التصويت سواء حل واحد متفوق على الآخر أو إذا كانوا جيدين بالتساوي إجمالي 453 استجابة تم جمعها خلال التقييم ملاحظة تقييم بشري فقط لمجتمع ذكاء اصطناعي حيث تقييم الكود أصعب بشكل عام للبشر بدون تشغيل الكود]
  HUMAN_EVAL --> GPT4_EVAL[تقييم GPT4 إشراك وكيل GPT4 لتقييم فعالية نموذج1 حل وكيل CAMEL مقابل نموذج2 حل لقطة واحدة gpt-3.5-turbo لكل مهمة على وجه التحديد موجه GPT4 لتسجيل وتقرير أي حل من الحلين أفضل النتائج ملخصة جدول1 يعرض حل CAMEL يتفوق على لقطة واحدة gpt-3.5-turbo]
  GPT4_EVAL --> EMERGENCE[ظهور معرفة دراسة ظهور معرفة LLMs عبر ضبط دقيق LLaMA على مجموعات بيانات متنامية تدريجيًا تم توليدها من خلال الإطار بالإضافة إلى ذلك تقييم قدرات توليد الكود من خلال قياس النموذج النهائي على HumanEval و HumanEval+]
  EMERGENCE --> END([نهاية CAMEL لعب أدوار مع توجيه بدء تعاون مستقل تدخل بشري أدنى فقط فكرة أولية مطلوبة توليد بيانات قابل للتوسع محادثة موجهة تعليمات موجهة مهام يتفوق على لقطة واحدة])
